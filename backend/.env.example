# Supabase — from your project settings at https://supabase.com/dashboard
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App
APP_ENV=development
SECRET_KEY=generate-a-random-64-char-string-here
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ML Model settings (defaults work fine for development)
E5_MODEL_NAME=intfloat/e5-large
BART_MODEL_NAME=facebook/bart-large-mnli
FAISS_INDEX_DIR=./data/faiss_index
MODEL_CACHE_DIR=./data/models
